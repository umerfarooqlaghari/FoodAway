{
  "cli": {
    "version": ">= 12.5.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:3000/api"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://goodtogo-ymoe.onrender.com/api"
      }
    },
    "production": {
      "distribution": "store",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://goodtogo-ymoe.onrender.com/api",
        "EXPO_USE_PRECOMPILED_MODULES": "0"
      }
    },
    "production-apk": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://goodtogo-ymoe.onrender.com/api"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6781679450",
         "ascApiKeyPath": "../AuthKey.p8",
        "ascApiKeyIssuerId": "138bd8ae-ea40-4c7b-a543-2964deb4a55b",
        "ascApiKeyId": "VTVNRS996B"
      },
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "internal"
      }
    }
  }
}