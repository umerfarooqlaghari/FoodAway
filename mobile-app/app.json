{
  "expo": {
    "name": "FoodAway",
    "slug": "mobile-app",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobileapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.alphadevs.mobileapp",
      "buildNumber": "5",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIRequiresFullScreen": true,
        "LSRequiresIPhoneOS": true,
        "NSCameraUsageDescription": "FoodAway needs camera access to upload store and food images.",
        "NSPhotoLibraryUsageDescription": "FoodAway needs photo library access to select store and food images.",
        "NSPhotoLibraryAddUsageDescription": "FoodAway saves images to your photo library.",
        "NSLocationWhenInUseUsageDescription": "FoodAway uses your location to show nearby stores.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "FoodAway uses your location to show nearby stores.",
        "NSUserNotificationsUsageDescription": "FoodAway sends you order updates and alerts."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FF5A00",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sharing",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#FF5A00",
          "defaultChannel": "default",
          "sounds": []
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "FoodAway uses your location to show nearby stores.",
          "locationWhenInUsePermission": "FoodAway uses your location to show nearby stores."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "FoodAway needs photo library access to select images.",
          "cameraPermission": "FoodAway needs camera access to take photos."
        }
      ],
      "expo-image"
    ],
    "experiments": {},
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6944ca8b-950c-4cae-ae56-c849fa660e57"
      }
    }
  }
}
