{
  "expo": {
    "name": "Grabengo",
    "slug": "mobile-app",
    "version": "1.1.8",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "grabengo",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.alphadevs.mobileapp",
      "buildNumber": "29",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIRequiresFullScreen": true,
        "LSRequiresIPhoneOS": true,
        "NSCameraUsageDescription": "Grabengo needs camera access to upload store and food images.",
        "NSPhotoLibraryUsageDescription": "Grabengo needs photo library access to select store and food images.",
        "NSPhotoLibraryAddUsageDescription": "Grabengo saves images to your photo library.",
        "NSLocationWhenInUseUsageDescription": "Grabengo uses your location to show nearby stores.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Grabengo uses your location to show nearby stores.",
        "NSUserNotificationsUsageDescription": "Grabengo sends you order updates and alerts."
      }
    },
    "android": {
      "package": "com.grabengo.app",
      "versionCode": 29,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBLxu-iMnH8KQnlVvjPKpXEu-aakSohOLo"
        }
      },
      "adaptiveIcon": {
        "backgroundColor": "#FF5C00",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "ios": {
            "backgroundColor": "#FFFFFF",
            "image": "./assets/images/icon.png",
            "imageWidth": 200
          },
          "android": {
            "backgroundColor": "#FFFFFF",
            "image": "./assets/images/icon.png",
            "imageWidth": 200
          }
        }
      ],
      "expo-sharing",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Grabengo uses your location to show nearby stores.",
          "locationWhenInUsePermission": "Grabengo uses your location to show nearby stores."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Grabengo needs photo library access to select images.",
          "cameraPermission": "Grabengo needs camera access to take photos.",
          "microphonePermission": false
        }
      ],
      "expo-image",
      "expo-asset",
      "@react-native-community/datetimepicker",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.4",
            "usePrecompiledModules": false,
            "buildReactNativeFromSource": true
          }
        }
      ]
    ],
    "experiments": {},
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0388fcf5-5a72-45a0-85b1-d445a6a07f23"
      }
    },
    "owner": "umer.farooq"
  }
}
